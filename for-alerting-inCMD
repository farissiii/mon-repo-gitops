cat <<EOF | kubectl apply -f -
apiVersion: monitoring.coreos.com/v1
kind: PrometheusRule
metadata:
  name: flask-app-rules
  namespace: monitoring
  labels:
    app: kube-prometheus-stack
    release: monitoring-stack
spec:
  groups:
  - name: flask.rules
    rules:
    - alert: FlaskAppDown
      expr: up{pod=~"flask-app.*"} == 0
      for: 1m
      labels:
        severity: critical
      annotations:
        summary: "ALERTE: L'application Python est tombée !"
EOF
